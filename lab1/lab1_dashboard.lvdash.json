    {
      "name": "top10_xg_goals",
      "displayName": "Top 10 Players xG vs Goals",
      "queryLines": [
        "WITH top10 AS (\n",
        "  SELECT\n",
        "    `Player Names`,\n",
        "    SUM(xG) AS total_xG,\n",
        "    SUM(Goals) AS total_Goals\n",
        "  FROM\n",
        "    dbr_dev.w_k_palczewski.football_scorers\n",
        "  GROUP BY\n",
        "    `Player Names`\n",
        "  ORDER BY\n",
        "    SUM(xG) DESC\n",
        "  LIMIT 10\n",
        ")\n",
        "SELECT\n",
        "  `Player Names`,\n",
        "  'xG' AS Metric,\n",
        "  total_xG AS Value\n",
        "FROM\n",
        "  top10\n",
        "UNION ALL\n",
        "SELECT\n",
        "  `Player Names`,\n",
        "  'Goals' AS Metric,\n",
        "  CAST(total_Goals AS DOUBLE) AS Value\n",
        "FROM\n",
        "  top10"
      ]
    }
  ],
